{
  "schemaVersion": 1,
  "pluginType": "data-transform",
  "pluginId": "hpop-sdn-plugin",
  "pluginName": "High-Precision Orbit Propagator",
  "pluginVersion": "1.0.0",
  "vendorId": "the-lobsternaut",
  "contact": "https://github.com/the-lobsternaut",
  "description": "Parses 18 SPCS text VCM to OCM FlatBuffers, propagates SP orbits with full force model stack (two-body, geopotential, drag, SRP, Sun/Moon), outputs OEM FlatBuffers",
  "capabilities": [
    "data.convert",
    "data.transform",
    "orbit.propagate"
  ],
  "inputFormats": [
    {
      "format": "text/vcm",
      "description": "18 SPCS fixed-format ASCII VCM (V2.0)",
      "fileIdentifier": null,
      "contentType": "text/plain"
    },
    {
      "format": "flatbuffers/vcm",
      "description": "spacedatastandards.org VCM FlatBuffer",
      "fileIdentifier": "$VCM"
    },
    {
      "format": "application/json",
      "description": "Propagation request JSON (simplified or VCM-schema)"
    }
  ],
  "outputFormats": [
    {
      "format": "flatbuffers/ocm",
      "description": "spacedatastandards.org OCM FlatBuffer",
      "fileIdentifier": "$OCM"
    },
    {
      "format": "flatbuffers/oem",
      "description": "spacedatastandards.org OEM FlatBuffer",
      "fileIdentifier": "$OEM"
    },
    {
      "format": "text/vcm",
      "description": "18 SPCS fixed-format ASCII VCM (V2.0)"
    },
    {
      "format": "text/oem",
      "description": "CCSDS OEM text format"
    }
  ],
  "forceModels": [
    "twobody",
    "geopotential-egm96",
    "drag-harris-priester",
    "srp-conical",
    "thirdbody-sun",
    "thirdbody-moon"
  ],
  "integrator": "rkf78",
  "wasmSize": "270KB",
  "exports": {
    "cabi": ["parse", "convert", "malloc", "free"],
    "embind": ["propagate", "propagateVCM", "parseVCM", "convertOCM", "getVersion", "getForceModels"]
  },
  "tests": {
    "native": "220 tests across 8 suites",
    "wasm": "4 smoke tests (Node.js)"
  }
}
